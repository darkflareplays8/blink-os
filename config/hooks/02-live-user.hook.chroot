#!/bin/bash
set -e

if ! id blink &>/dev/null; then
    useradd -m -s /bin/bash -G sudo,audio,cdrom,dip,floppy,video,plugdev,netdev blink
fi

echo "blink:live" | chpasswd
echo "root:live" | chpasswd

mkdir -p /etc/live
printf 'LIVE_USERNAME="blink"\nLIVE_USER_FULLNAME="Blink OS"\nLIVE_HOSTNAME="blink"\n' \
    > /etc/live/config.conf

echo "blink ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/blink-nopasswd
chmod 440 /etc/sudoers.d/blink-nopasswd
